<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="001-users" author="chatly">
    <createTable tableName="app_user">
      <column name="id" type="uuid">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="email" type="text">
        <constraints nullable="false" unique="true"/>
      </column>
      <column name="password_hash" type="text">
        <constraints nullable="false"/>
      </column>
      <column name="role" type="text">
        <constraints nullable="false"/>
      </column>
      <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()">
        <constraints nullable="false"/>
      </column>
    </createTable>
  </changeSet>

  <changeSet id="002-document-sources" author="chatly">
    <createTable tableName="document_source">
      <column name="id" type="uuid">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="name" type="text">
        <constraints nullable="false"/>
      </column>
      <column name="type" type="text">
        <constraints nullable="false"/>
      </column>
      <column name="config" type="jsonb">
        <constraints nullable="false"/>
      </column>
      <column name="status" type="text" defaultValue="IDLE">
        <constraints nullable="false"/>
      </column>
      <column name="last_error" type="text"/>
      <column name="last_synced_at" type="timestamp with time zone"/>
      <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()">
        <constraints nullable="false"/>
      </column>
    </createTable>
  </changeSet>

  <changeSet id="003-documents" author="chatly">
    <createTable tableName="document">
      <column name="id" type="uuid">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="source_id" type="uuid">
        <constraints nullable="false" foreignKeyName="fk_document_source" references="document_source(id)" deleteCascade="true"/>
      </column>
      <column name="title" type="text">
        <constraints nullable="false"/>
      </column>
      <column name="uri" type="text">
        <constraints nullable="false"/>
      </column>
      <column name="checksum" type="text">
        <constraints nullable="false"/>
      </column>
      <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()">
        <constraints nullable="false"/>
      </column>
    </createTable>
    <addUniqueConstraint tableName="document" columnNames="source_id, uri" constraintName="uk_document_source_uri"/>
    <createIndex tableName="document" indexName="idx_document_checksum">
      <column name="checksum"/>
    </createIndex>
  </changeSet>

  <changeSet id="004-document-chunks" author="chatly">
    <createTable tableName="document_chunk">
      <column name="id" type="uuid">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="document_id" type="uuid">
        <constraints nullable="false" foreignKeyName="fk_chunk_document" references="document(id)" deleteCascade="true"/>
      </column>
      <column name="ordinal" type="integer">
        <constraints nullable="false"/>
      </column>
      <column name="content" type="text">
        <constraints nullable="false"/>
      </column>
      <column name="embedding" type="jsonb">
        <constraints nullable="false"/>
      </column>
      <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()">
        <constraints nullable="false"/>
      </column>
    </createTable>
    <createIndex tableName="document_chunk" indexName="idx_chunk_document">
      <column name="document_id"/>
    </createIndex>
  </changeSet>

  <changeSet id="005-chat" author="chatly">
    <createTable tableName="chat">
      <column name="id" type="uuid">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="user_id" type="uuid">
        <constraints nullable="false" foreignKeyName="fk_chat_user" references="app_user(id)" deleteCascade="true"/>
      </column>
      <column name="title" type="text">
        <constraints nullable="false"/>
      </column>
      <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()">
        <constraints nullable="false"/>
      </column>
      <column name="updated_at" type="timestamp with time zone" defaultValueComputed="now()">
        <constraints nullable="false"/>
      </column>
    </createTable>
    <createTable tableName="chat_message">
      <column name="id" type="uuid">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="chat_id" type="uuid">
        <constraints nullable="false" foreignKeyName="fk_message_chat" references="chat(id)" deleteCascade="true"/>
      </column>
      <column name="role" type="text">
        <constraints nullable="false"/>
      </column>
      <column name="content" type="text">
        <constraints nullable="false"/>
      </column>
      <column name="sources" type="jsonb"/>
      <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()">
        <constraints nullable="false"/>
      </column>
    </createTable>
  </changeSet>

  <changeSet id="006-model-settings" author="chatly">
    <createTable tableName="model_setting">
      <column name="key" type="text">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="value" type="text">
        <constraints nullable="false"/>
      </column>
      <column name="updated_at" type="timestamp with time zone" defaultValueComputed="now()">
        <constraints nullable="false"/>
      </column>
    </createTable>
    <insert tableName="model_setting">
      <column name="key" value="embeddingModel"/>
      <column name="value" value="models/embedding.gguf"/>
    </insert>
    <insert tableName="model_setting">
      <column name="key" value="chatModel"/>
      <column name="value" value="models/chat.gguf"/>
    </insert>
    <insert tableName="model_setting">
      <column name="key" value="topK"/>
      <column name="value" value="6"/>
    </insert>
    <insert tableName="model_setting">
      <column name="key" value="temperature"/>
      <column name="value" value="0.2"/>
    </insert>
  </changeSet>
</databaseChangeLog>
